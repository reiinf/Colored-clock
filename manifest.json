{
  "manifest_version": 2,
  "name": "Time Tracker",
  "version": "1.0.0",
  "description": "Hourly schedule and usage trend tracker",

  "permissions": [
    "storage",
    "alarms"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_title": "Time Tracker",
    "default_popup": "popup.html"
  },

  "icons": {
    "48": "icons/clock48.png",
    "96": "icons/clock96.png"
  }
}
